# Supabase (required for /admin and optional for blog content)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: for seeding blog posts (Dashboard → API → service_role secret)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: for running migrations locally and seeding blog posts
# Project Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Resend (required for /buyer-form to send emails to eliteaccelerator@gmail.com)
RESEND_API_KEY=re_xxxxx
# Optional: custom from address (must be verified in Resend); defaults to onboarding@resend.dev
# RESEND_FROM=Acquire To Scale <hello@acquiretoscale.com>
