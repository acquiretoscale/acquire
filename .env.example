# Supabase (required for /admin and optional for blog content)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend (required for /buyer-form to send emails to eliteaccelerator@gmail.com)
RESEND_API_KEY=re_xxxxx
# Optional: custom from address (must be verified in Resend); defaults to onboarding@resend.dev
# RESEND_FROM=Acquire To Scale <hello@acquiretoscale.com>
